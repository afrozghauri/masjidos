# ---- LLM ----
OPENAI_API_KEY=sk-your-key-here
VLM_MODEL=gpt-4o
AGENT_MODEL=gpt-4o

# ---- Confidence policy ----
# The agent auto-publishes only when its minimum per-field confidence is >= this.
# Anything below is escalated to the human review gate.
CONFIDENCE_THRESHOLD=0.80

# Either a local file path (.xlsx/.xls/.csv) OR a Google Sheets share link.
# For Google Sheets: no public sharing is needed — just share the sheet as
# Editor with the service account's client_email (see GOOGLE_SERVICE_ACCOUNT_JSON
# below). You can also override this per-run via the `source` argument.
MASJID_DIRECTORY=data/masjids.xlsx

# Required ONLY if you want the app to write "Done" back into a Google Sheet.
# Path to a Google service account JSON key. That service account's email
# (found inside the JSON as "client_email") must be given EDITOR access on
# the sheet — Share > add that email > Editor. A public "view" link is NOT
# enough for writing.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Masjidal portal (deterministic upload; NOT the AI part) ----
PORTAL_LOGIN_URL=https://masjidal.com/backend/site/login
PORTAL_EMAIL=info@masjidal.com
PORTAL_PASSWORD=changeme
# Set true only when you actually want Playwright to log in and upload.
# Keep false for safe demos (CSVs are still generated on disk).
PORTAL_UPLOAD_ENABLED=false
# Set to false during a live demo to watch a real Chrome window log in and
# upload the CSVs. Keep true for normal/headless/Docker runs.
PORTAL_HEADLESS=true

# ---- Storage ----
DATABASE_URL=sqlite:///data/masjidos.db
OUTPUT_DIR=data/outputs

# ---- API security ----
# Required X-API-Key header value for every app/api.py route except /health.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
# Comma-separated list of allowed browser origins for CORS; "*" for local/demo use,
# restrict to your actual frontend origin(s) in a real deployment.
CORS_ALLOW_ORIGINS=*

# ---- Observability ----
# Free tracing for the LangGraph agent's tool-call reasoning at smith.langchain.com.
# Get a key at https://smith.langchain.com, then set LANGCHAIN_TRACING_V2=true.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=masjidos
LOG_DIR=data/logs
